# BACKEND — FASTAPI

Create:

```bash
backend/app/main.py
```

```python
from fastapi import FastAPI, WebSocket
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/api/health")
async def health():
    return {
        "engine": "nova-sonic",
        "credentialSource": "configured"
    }

@app.post("/api/classify")
async def classify(payload: dict):

    transcript = payload.get("transcript", "").lower()

    if "income" in transcript:
        return {
            "screen": "income_details",
            "highlight": ["income", "calcBasis"],
            "guidance": "Review income details",
            "step": 2
        }

    if "complaint" in transcript:
        return {
            "screen": "notes_screen",
            "highlight": ["noteText"],
            "guidance": "Log complaint details",
            "step": 3
        }

    return {
        "screen": "case_overview",
        "highlight": ["ref"],
        "guidance": "Verify customer identity",
        "step": 0
    }

@app.websocket("/ws/voice")
async def websocket_endpoint(websocket: WebSocket):

    await websocket.accept()

    await websocket.send_json({
        "type": "session_started"
    })

    while True:
        data = await websocket.receive_text()

        await websocket.send_json({
            "type": "transcript",
            "role": "ASSISTANT",
            "text": "I lost my job three weeks ago."
        })

        await websocket.send_json({
            "type": "turn_end",
            "role": "ASSISTANT"
        })
```

